# Django
SECRET_KEY=nexus-change-this-in-production-use-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80
CORS_ALLOW_ALL_ORIGINS=False

# Database
DB_ENGINE=postgresql
DB_NAME=nexus_db
DB_USER=nexus_user
DB_PASSWORD=nexus_pass
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# Throttling
THROTTLE_ANON_RATE=20/hour
THROTTLE_USER_RATE=1000/hour

# Frontend API URL (for production builds)
REACT_APP_API_URL=/api

# Seed data on startup
SEED_DATA=true

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Social Media API Keys
ANTHROPIC_API_KEY=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TWITTER_API_KEY=
TWITTER_API_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
